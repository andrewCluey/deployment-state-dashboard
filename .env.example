# ─── Pipeline Dashboard — Environment Variables ───────────────────────────────
#
# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit it.
#
# In Azure App Service, set these as Application Settings instead.
# On App Service with Managed Identity, you only need AZURE_STORAGE_ACCOUNT
# and AZURE_TABLE_NAME — the identity vars are not needed.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure Storage ─────────────────────────────────────────────────────────────
# The name of your storage account (not the full URL)
AZURE_STORAGE_ACCOUNT=mystorageaccount

# The table name within the storage account (default: PipelineStatus)
AZURE_TABLE_NAME=PipelineStatus

# ── Service Principal (local dev only) ────────────────────────────────────────
# These are picked up automatically by DefaultAzureCredential as EnvironmentCredential.
# On Azure App Service with Managed Identity, leave these unset.
#
# Create an App Registration in Entra ID, generate a client secret,
# then grant it "Storage Table Data Reader" on your storage account.
#
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
